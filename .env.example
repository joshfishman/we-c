# ============================================================
# WE Creative — environment variables
# Copy to `.env.local` for local dev, or set in Vercel for prod.
# ============================================================

# ---- Local development ----
# When "true", TinaCMS runs in LOCAL mode: filesystem content, no auth,
# no database, no GitHub. This is all you need to run `npm run dev`.
TINA_PUBLIC_IS_LOCAL=true

# ---- Conversion tracking (optional locally, set in prod) ----
# Google Tag Manager container id. Configure GA4 / Ads / Meta tags inside GTM.
NEXT_PUBLIC_GTM_ID=

# ---- Behaviour tracking (optional) ----
# Microsoft Clarity project id — session replay + heatmaps. Get it at
# clarity.microsoft.com (free). Suppressed inside the Tina editor.
NEXT_PUBLIC_CLARITY_ID=

# ============================================================
# PRODUCTION ONLY (Vercel) — set TINA_PUBLIC_IS_LOCAL=false there
# ============================================================

# GitHub: where TinaCMS commits content edits (the editor "publishes" here).
GITHUB_PERSONAL_ACCESS_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main

# ---- Editor login (Supabase Auth) ----
# URL + anon key are public by design (safe in the browser).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# WHO may edit. Authentication is not authorization: without this, ANY account
# that can sign up in the Supabase project could edit the site. Comma-separated
# emails. Empty = nobody (fails closed) and /admin stays 404.
TINA_ALLOWED_EMAILS=

# Tina datalayer (content index) in prod: an Upstash Redis store.
# Vercel KV is retired — use Vercel → Storage → Marketplace → Upstash, or
# upstash.com directly. UPSTASH_REDIS_REST_URL / _TOKEN also work.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Contact form + lead quiz (optional — both post to this one Formspree form,
# and default to the wired id below). This is the form *id*, not a URL: the
# code reads NEXT_PUBLIC_FORMSPREE_ID. The old ..._ENDPOINT variable was never
# read by anything, so setting it silently did nothing.
NEXT_PUBLIC_FORMSPREE_ID=mdarygor
